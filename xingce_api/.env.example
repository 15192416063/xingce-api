# 复制本文件为 .env 并填入真实值。⚠️ 真实密钥只写进 .env(已被gitignore),
# 切勿写进本 .env.example —— 它会被提交到 git!
# ===== 必填(上线务必设置)=====
XC_SECRET_KEY=改成一长串随机字符串_用于令牌签名_泄露则账号可被伪造
DEEPSEEK_API_KEY=你的DeepSeek_key
# 向量 embedding(找相似/AI推荐用)。去 siliconflow.cn 注册,免费额度,拿一个 key。
XC_EMBED_KEY=你的硅基流动key
# 可选:换别的 OpenAI 兼容 embedding 服务时再改下面两行
# XC_EMBED_BASE_URL=https://api.siliconflow.cn/v1
# XC_EMBED_MODEL=BAAI/bge-large-zh-v1.5

# ===== 数据库(默认SQLite;上线建议MySQL)=====
# XC_DB_URL=mysql+pymysql://user:pass@127.0.0.1:3306/xingce?charset=utf8mb4
# XC_DB_URL=sqlite:///xingce_demo.db

# ===== 业务 =====
XC_ADMIN_CODE=改成你自己的管理员邀请码
XC_BETA_FREE=true                 # 内测期true(会员功能免费);正式收费改false
XC_EXAM_NAME=2027国家公务员考试
XC_EXAM_DATE=2026-11-29
XC_FREE_DAILY_AI=20
