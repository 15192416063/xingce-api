# 行测相似题检索系统 — 环境变量配置模板
# 用法：复制本文件为 .env，填入真实值。代码用 python-dotenv 读取。
# ⚠️ 千万不要把填了真实 key 的 .env 提交到代码仓库！（已在 .gitignore 中排除）

# ========== 方案 A：使用 OpenAI ==========
OPENAI_API_KEY=sk-你的key

# ========== 方案 B：使用国产模型（兼容 OpenAI 接口）==========
# 多数国产模型兼容 OpenAI SDK，填 key + base_url 即可，无需改代码逻辑。
# 取消下面对应几行的注释，并注释掉上面的 OPENAI_API_KEY。

# --- DeepSeek ---
# OPENAI_API_KEY=你的deepseek_key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# --- 通义千问（阿里）---
# OPENAI_API_KEY=你的dashscope_key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# --- 智谱 GLM ---
# OPENAI_API_KEY=你的zhipu_key
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# ========== 通用参数 ==========
# 提炼考点用的 LLM（便宜的小模型即可）
LLM_MODEL=gpt-4o-mini
# embedding 模型（中文场景务必选中文支持好的；建库和检索必须用同一个）
EMBEDDING_MODEL=text-embedding-3-small
# 管理员口令（MVP 用；产品化换正规登录）
ADMIN_PASSWORD=改成你自己的强口令
